# ============================================================
# AgenticBro Bounty Agent — Environment Configuration
# ============================================================
# Copy this to .env and fill in your values before running.

# --- Solana Wallet ---
# Path to your Solana keypair JSON file (array of 64 bytes)
# Generate with: solana-keygen new --outfile ./wallet.json
WALLET_PATH=./wallet.json

# Your Solana wallet public key (base58)
# Gets set automatically by scripts/setup.js after wallet creation
AGENT_WALLET_PUBKEY=

# --- Synapse / OOBE Protocol RPC ---
# Free tier available at https://synapse.oobeprotocol.ai/
# For higher limits, ask for discount in their Discord
SYNAPSE_RPC_URL=https://us-1-mainnet.oobeprotocol.ai/rpc?api_key=YOUR_SYNAPSE_API_KEY

# Use devnet for testing (free SOL from faucet.solana.com)
# SYNAPSE_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=mainnet-beta

# --- Ace Data Cloud ---
# Sign up at https://platform.acedata.cloud (free credits on registration)
# Get your API key from the dashboard
ACE_DATA_API_KEY=YOUR_ACE_DATA_API_KEY
ACE_DATA_BASE_URL=https://api.acedata.cloud

# --- Agent Configuration ---
AGENT_NAME=AgenticBro-Sentinel
AGENT_DESCRIPTION=AgenticBro scam detection agent — discovers threats, analyzes tokens, and settles payments autonomously on Solana. Built by Agentic Insights LLC.
AGENT_ENDPOINT=https://your-agent-endpoint.com/x402

# --- Sentinel Agent (required for bounty) ---
# The Synapse Sentinel agent address from the bounty docs
SENTINEL_AGENT_ADDRESS=Ccr2yK3hLALU4p8oNRqrh4dGuvPJTth5KCLMio8cE1ph

# --- Workflow Settings ---
# How many milliseconds between automated workflow runs (default: 60 seconds)
WORKFLOW_INTERVAL_MS=60000

# How many Ace Data Cloud API calls to make per workflow cycle
CALLS_PER_CYCLE=3

# Lamports to deposit into escrow per cycle (1 SOL = 1,000,000,000 lamports)
ESCROW_DEPOSIT_LAMPORTS=5000000

# --- Dashboard ---
DASHBOARD_PORT=3333
